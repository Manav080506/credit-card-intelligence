{
 "manifest_version":3,

 "name":"Card Optimizer",

 "version":"1.0",

 "permissions":[
  "activeTab",
  "storage"
 ],

 "host_permissions":[
  "https://*/*"
 ],

 "action":{
  "default_popup":"popup.html"
 },

 "content_scripts":[
  {
   "matches":[
    "*://*.amazon.*/*",
    "*://*.flipkart.*/*",
    "*://*.swiggy.*/*"
   ],

   "js":[
    "content.js"
   ]
  }
 ]
}
