{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Card Benefit Knowledge Graph",
  "type": "object",
  "required": ["version", "nodes", "edges"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "properties": {
          "id": {"type": "string"},
          "type": {
            "type": "string",
            "enum": [
              "card",
              "issuer",
              "reward_category",
              "benefit",
              "merchant",
              "persona",
              "milestone",
              "fee_band"
            ]
          },
          "name": {"type": "string"},
          "attributes": {"type": "object"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "relation"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "relation": {
            "type": "string",
            "enum": [
              "ISSUED_BY",
              "HAS_REWARD_RATE",
              "HAS_BENEFIT",
              "HAS_MILESTONE",
              "SUITS_PERSONA",
              "ELIGIBLE_AT_FEE_BAND",
              "EARNS_AT_MERCHANT",
              "COMPETES_WITH",
              "DERIVED_FROM"
            ]
          },
          "weight": {"type": "number"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "attributes": {"type": "object"}
        }
      }
    }
  }
}
